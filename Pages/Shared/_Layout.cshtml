@{
    string? currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    bool isIndex = currentPage == "/" || string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase);
    bool isCreate = string.Equals(currentPage, "/Rezepte/Create", StringComparison.OrdinalIgnoreCase);
    bool isRandom = string.Equals(currentPage, "/Random", StringComparison.OrdinalIgnoreCase);
    bool isWochenplan = string.Equals(currentPage, "/Wochenplan", StringComparison.OrdinalIgnoreCase);
    bool isEinkaufsliste = string.Equals(currentPage, "/Einkaufsliste", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <script>(function(){var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t);})()</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KuechenRezepte</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Syne:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Direkt zum Inhalt springen</a>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar" aria-label="Hauptnavigation">
            <div class="container">
                <div class="navbar-shell">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">KuechenRezepte</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Navigation umschalten">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div id="mainNav" class="navbar-collapse collapse">
                        <ul class="navbar-nav ms-auto align-items-lg-center">
                            <li class="nav-item">
                                <a class="nav-link @(isIndex ? "active" : "")" aria-current="@(isIndex ? "page" : null)" asp-area="" asp-page="/Index">Alle Rezepte</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isCreate ? "active" : "")" aria-current="@(isCreate ? "page" : null)" asp-area="" asp-page="/Rezepte/Create">Neues Rezept</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isRandom ? "active" : "")" aria-current="@(isRandom ? "page" : null)" asp-area="" asp-page="/Random">Inspiration</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isWochenplan ? "active" : "")" aria-current="@(isWochenplan ? "page" : null)" asp-area="" asp-page="/Wochenplan">Wochenplan</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isEinkaufsliste ? "active" : "")" aria-current="@(isEinkaufsliste ? "page" : null)" asp-area="" asp-page="/Einkaufsliste">Einkaufsliste</a>
                            </li>
                            <li class="nav-item">
                                <button type="button" id="theme-toggle" class="btn btn-link nav-link px-2"
                                        title="Darkmodus umschalten" aria-label="Darkmodus umschalten">
                                    <span id="theme-icon">&#9790;</span>
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-shell">
        <main id="main-content" role="main" tabindex="-1">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container footer-shell">
            <span>&copy; 2026 - KuechenRezepte</span>
            <a class="footer-credit" href="https://schmid-digital.at" target="_blank" rel="noopener noreferrer">gemacht von schmid-digital.at</a>
        </div>
    </footer>

    <div class="modal fade" id="imageLightboxModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content image-lightbox">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
                </div>
                <div class="modal-body pt-0">
                    <img id="imageLightboxImage" src="" alt="Bildvorschau" class="image-lightbox-img" />
                    <div id="imageLightboxCaption" class="image-lightbox-caption"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

