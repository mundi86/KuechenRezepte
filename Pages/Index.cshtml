@page
@model KuechenRezepte.Pages.IndexModel
@{
    ViewData["Title"] = "Alle Rezepte";
}

<section class="hero-panel home-hero mb-4">
    <div class="home-hero-grid">
        <div>
            <p class="hero-kicker mb-2">KÜCHENREZEPTE ARCHIVE</p>
            <h1 class="mb-3">Dein kulinarisches Cockpit mit Stil, Struktur und Tempo.</h1>
            <p class="hero-sub mb-4">Suche, plane und entdecke Rezepte in einer Oberfläche, die sich wie ein Magazin und ein Tool zugleich anfühlt.</p>
            <div class="d-flex flex-wrap gap-2 mb-4">
                <a asp-page="/Rezepte/Create" class="btn btn-primary">Neues Rezept anlegen</a>
                <a asp-page="/Random" class="btn btn-warning">Überrasche mich</a>
                <a asp-page="/Wochenplan" class="btn btn-outline-secondary">Wochenplan öffnen</a>
            </div>
            <div class="hero-metrics">
                <div class="hero-metric">
                    <span class="hero-metric-value">@Model.TotalCount</span>
                    <span class="hero-metric-label">Rezepte gesamt</span>
                </div>
                <div class="hero-metric">
                    <span class="hero-metric-value">@Model.ZutatenVorschlaege.Count</span>
                    <span class="hero-metric-label">Zutaten indexiert</span>
                </div>
                <div class="hero-metric">
                    <span class="hero-metric-value">12</span>
                    <span class="hero-metric-label">Rezepte pro Seite</span>
                </div>
            </div>
        </div>
        <aside class="hero-aside">
            <div class="hero-aside-card">
                <h3 class="h5 mb-2">Discovery Flow</h3>
                <p class="small text-muted mb-3">Von der Idee bis zur Einkaufsliste in wenigen Klicks.</p>
                <ul class="hero-flow mb-0">
                    <li><span>1</span> Suche nach Geschmack oder Zutat</li>
                    <li><span>2</span> Speichere Favoriten als Wochenplan</li>
                    <li><span>3</span> Erzeuge automatisch die Einkaufsliste</li>
                </ul>
            </div>
            <div class="hero-signature" aria-hidden="true"></div>
        </aside>
    </div>
</section>

<section class="glass-panel discovery-panel mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-6">
            <label class="form-label">Suche</label>
            <div class="input-group">
                <input asp-for="SearchTerm" class="form-control" placeholder="Rezept oder Zutat eingeben" list="zutaten-suche-liste">
                <button class="btn btn-primary" type="submit">Suchen</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a asp-page="/Index" class="btn btn-outline-secondary">Reset</a>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <label class="form-label">Kategorie</label>
            <select asp-for="Kategorie" class="form-select" asp-items="Html.GetEnumSelectList<Kategorie>()">
                <option value="">Alle Kategorien</option>
            </select>
        </div>
        <div class="col-lg-2 d-grid">
            <a asp-page="/Random" class="btn btn-outline-primary">Zufälliges Rezept</a>
        </div>
    </form>
</section>

<datalist id="zutaten-suche-liste">
    @foreach (var vorschlag in Model.ZutatenVorschlaege)
    {
        <option value="@vorschlag"></option>
    }
</datalist>

@if (Model.Rezepte.Any())
{
    <section class="mb-3 d-flex justify-content-between align-items-end gap-3 flex-wrap">
        <div>
            <h2 class="h4 mb-1">Aktuelle Rezeptauswahl</h2>
            <p class="text-muted mb-0">Kuratiert nach Suchbegriff, Kategorie und Veröffentlichungsdatum.</p>
        </div>
        <span class="badge bg-secondary px-3 py-2">Seite @Model.PageNumber von @Math.Max(1, Model.TotalPages)</span>
    </section>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 stagger-grid">
        @foreach (var rezept in Model.Rezepte)
        {
            <div class="col">
                <article class="card h-100 recipe-card">
                    <a asp-page="/Rezepte/Details" asp-route-id="@rezept.Id" class="stretched-link recipe-card-link" aria-label="Details zu @rezept.Name"></a>
                    @if (!string.IsNullOrEmpty(rezept.BildPfad))
                    {
                        <img src="@rezept.BildPfad" class="card-img-top recipe-img" alt="@rezept.Name">
                    }
                    else
                    {
                        <div class="card-img-top recipe-img-placeholder d-flex align-items-center justify-content-center">
                            <span class="placeholder-symbol">No image</span>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                            <h5 class="card-title mb-0">@rezept.Name</h5>
                            <span class="badge bg-secondary">@rezept.Kategorie</span>
                        </div>

                        @if (!string.IsNullOrEmpty(rezept.Beschreibung))
                        {
                            <p class="card-text small text-muted">@rezept.Beschreibung</p>
                        }

                        <div class="meta-strip mb-2">
                            @if (rezept.Zubereitungszeit.HasValue)
                            {
                                <span>@rezept.Zubereitungszeit Min</span>
                            }
                            <span class="ms-2">@rezept.Portionen Portionen</span>
                        </div>

                        <div class="small text-muted mb-3">
                            <strong>Zutaten:</strong>
                            @string.Join(", ", rezept.RezeptZutaten.Select(rz => rz.Zutat?.Name ?? ""))
                        </div>

                        <div class="d-flex gap-2 mt-auto card-actions">
                            <a asp-page="/Rezepte/Details" asp-route-id="@rezept.Id" class="btn btn-sm btn-primary">Details</a>
                            <a asp-page="/Rezepte/Edit" asp-route-id="@rezept.Id" class="btn btn-sm btn-outline-secondary">Bearbeiten</a>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
else
{
    <section class="content-panel text-center py-5">
        <h3 class="mb-2">Keine Rezepte gefunden</h3>
        <p class="text-muted mb-4">Lege dein erstes Rezept an und baue deine Sammlung auf.</p>
        <a asp-page="/Rezepte/Create" class="btn btn-primary">Neues Rezept</a>
    </section>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Seitennavigation" class="mt-4 d-flex justify-content-center">
        <ul class="pagination">
            @if (Model.PageNumber > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=@(Model.PageNumber - 1)&searchTerm=@Model.SearchTerm&kategorie=@Model.Kategorie">&#8249;</a>
                </li>
            }
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&searchTerm=@Model.SearchTerm&kategorie=@Model.Kategorie">@i</a>
                </li>
            }
            @if (Model.PageNumber < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=@(Model.PageNumber + 1)&searchTerm=@Model.SearchTerm&kategorie=@Model.Kategorie">&#8250;</a>
                </li>
            }
        </ul>
    </nav>
}
