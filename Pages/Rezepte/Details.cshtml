@page "{id:int}"
@model KuechenRezepte.Pages.Rezepte.DetailsModel
@{
    ViewData["Title"] = Model.Rezept?.Name ?? "Rezept";
}

@if (Model.Rezept == null)
{
    <section class="content-panel">
        <div class="alert alert-warning mb-0">Rezept nicht gefunden.</div>
        <a asp-page="/Index" class="btn btn-secondary mt-3">Zurück</a>
    </section>
    return;
}

<section class="hero-panel detail-hero mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <p class="hero-kicker mb-2">REZEPT DETAIL</p>
            <h1 class="mb-2">@Model.Rezept.Name</h1>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="badge bg-secondary">@Model.Rezept.Kategorie</span>
                <span class="meta-pill">Portionen: @Model.Rezept.Portionen</span>
                <span class="meta-pill">Zeit: @(Model.Rezept.Zubereitungszeit.HasValue ? $"{Model.Rezept.Zubereitungszeit} Min" : "n/a")</span>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-page="Edit" asp-route-id="@Model.Rezept.Id" class="btn btn-outline-primary">Bearbeiten</a>
            <a asp-page="Delete" asp-route-id="@Model.Rezept.Id" class="btn btn-outline-danger">Löschen</a>
            <a asp-page="/Index" class="btn btn-outline-secondary">Zur Übersicht</a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-xl-5">
        <section class="content-panel detail-media-panel h-100">
            <div class="image-stage detail-main-image">
                @if (Model.GalerieBilder.Any())
                {
                    <a href="@Model.GalerieBilder[0]" class="gallery-image-link" data-full-src="@Model.GalerieBilder[0]" data-caption="@Model.Rezept.Name">
                        <img src="@Model.GalerieBilder[0]" alt="@Model.Rezept.Name" />
                    </a>
                }
                else
                {
                    <div class="recipe-img-placeholder d-flex align-items-center justify-content-center" style="min-height: 340px;">
                        <span class="placeholder-symbol">No image</span>
                    </div>
                }
            </div>

            @if (Model.GalerieBilder.Count > 1)
            {
                <div class="row g-2 mt-2">
                    @foreach (var bild in Model.GalerieBilder.Skip(1))
                    {
                        <div class="col-4">
                            <div class="image-stage detail-thumb h-100">
                                <a href="@bild" class="gallery-image-link" data-full-src="@bild" data-caption="@Model.Rezept.Name">
                                    <img src="@bild" alt="@Model.Rezept.Name" />
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-xl-7">
        <section class="content-panel detail-content-panel h-100">
            @if (!string.IsNullOrWhiteSpace(Model.Rezept.Beschreibung))
            {
                <section class="detail-section">
                    <h4>Beschreibung</h4>
                    <p class="mb-0">@Model.Rezept.Beschreibung</p>
                </section>
            }

            <section class="detail-section">
                <h4>Zutaten</h4>
                <ul class="list-group detail-list">
                    @foreach (var rz in Model.Rezept.RezeptZutaten)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <strong>@rz.Zutat?.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(rz.Menge))
                            {
                                <span class="text-muted">@rz.Menge @rz.Einheit</span>
                            }
                        </li>
                    }
                </ul>
            </section>

            @if (!string.IsNullOrWhiteSpace(Model.Rezept.Zubereitung))
            {
                <section class="detail-section mb-0">
                    <h4>Zubereitung</h4>
                    <div class="detail-copy">@Model.Rezept.Zubereitung</div>
                </section>
            }

            <div class="small text-muted mt-4">Erstellt: @Model.Rezept.CreatedAt.ToString("dd.MM.yyyy")</div>
        </section>
    </div>
</div>
