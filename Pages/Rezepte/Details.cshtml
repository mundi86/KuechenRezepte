@page "{id:int}"
@model KuechenRezepte.Pages.Rezepte.DetailsModel
@{
    ViewData["Title"] = Model.Rezept?.Name ?? "Rezept";
}

@if (Model.Rezept == null)
{
    <section class="content-panel">
        <div class="alert alert-warning mb-0">Rezept nicht gefunden.</div>
        <a asp-page="/Index" class="btn btn-secondary mt-3">Zurueck</a>
    </section>
    return;
}

<div class="row g-4">
    <div class="col-lg-5">
        <section class="image-stage">
            @if (Model.GalerieBilder.Any())
            {
                <a href="@Model.GalerieBilder[0]" class="gallery-image-link" data-full-src="@Model.GalerieBilder[0]" data-caption="@Model.Rezept.Name">
                    <img src="@Model.GalerieBilder[0]" alt="@Model.Rezept.Name">
                </a>
            }
            else
            {
                <div class="recipe-img-placeholder d-flex align-items-center justify-content-center" style="min-height: 320px;">
                    <span class="placeholder-symbol">No image</span>
                </div>
            }
        </section>

        @if (Model.GalerieBilder.Count > 1)
        {
            <div class="row g-2 mt-2">
                @foreach (var bild in Model.GalerieBilder.Skip(1))
                {
                    <div class="col-4">
                        <div class="image-stage p-1">
                            <a href="@bild" class="gallery-image-link" data-full-src="@bild" data-caption="@Model.Rezept.Name">
                                <img src="@bild" alt="@Model.Rezept.Name" style="height: 85px; width: 100%; object-fit: cover;">
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-lg-7">
        <section class="content-panel h-100">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                <div>
                    <h1 class="mb-2">@Model.Rezept.Name</h1>
                    <span class="badge bg-secondary">@Model.Rezept.Kategorie</span>
                </div>
                <div class="d-flex gap-2">
                    <a asp-page="Edit" asp-route-id="@Model.Rezept.Id" class="btn btn-outline-primary">Bearbeiten</a>
                    <a asp-page="Delete" asp-route-id="@Model.Rezept.Id" class="btn btn-outline-danger">Loeschen</a>
                </div>
            </div>

            <div class="meta-strip mb-3">
                <span>Zubereitungszeit: @(Model.Rezept.Zubereitungszeit.HasValue ? $"{Model.Rezept.Zubereitungszeit} Minuten" : "Nicht angegeben")</span>
                <span class="ms-3">Portionen: @Model.Rezept.Portionen</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Rezept.Beschreibung))
            {
                <div class="mb-3">
                    <h5>Beschreibung</h5>
                    <p class="mb-0">@Model.Rezept.Beschreibung</p>
                </div>
            }

            <div class="mb-3">
                <h5>Zutaten</h5>
                <ul class="list-group">
                    @foreach (var rz in Model.Rezept.RezeptZutaten)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <strong>@rz.Zutat?.Name</strong>
                            @if (!string.IsNullOrEmpty(rz.Menge))
                            {
                                <span class="text-muted">@rz.Menge @rz.Einheit</span>
                            }
                        </li>
                    }
                </ul>
            </div>

            @if (!string.IsNullOrEmpty(Model.Rezept.Zubereitung))
            {
                <div class="mb-3">
                    <h5>Zubereitung</h5>
                    <div class="detail-copy">@Model.Rezept.Zubereitung</div>
                </div>
            }

            <div class="small text-muted">Erstellt: @Model.Rezept.CreatedAt.ToString("dd.MM.yyyy")</div>

            <a asp-page="/Index" class="btn btn-secondary mt-3">Zurueck zur Uebersicht</a>
        </section>
    </div>
</div>
