@page "/Random"
@model KuechenRezepte.Pages.RandomModel
@{
    ViewData["Title"] = "Zufälliges Rezept";
}

@if (Model.Rezept == null)
{
    <section class="content-panel">
        <div class="alert alert-warning mb-0">
            <h4 class="mb-2">Noch keine Rezepte vorhanden</h4>
            <p class="mb-3">Erstelle zuerst mindestens ein Rezept, damit wir etwas auslosen koennen.</p>
            <a asp-page="/Rezepte/Create" class="btn btn-primary">Neues Rezept erstellen</a>
        </div>
    </section>
    return;
}

<section class="content-panel text-center">
    <h2 class="mb-4">Heute kochst du:</h2>

    <article class="card recipe-card mx-auto" style="max-width: 620px;">
        <a asp-page="/Rezepte/Details" asp-route-id="@Model.Rezept.Id"
           class="stretched-link recipe-card-link" aria-label="Details zu @Model.Rezept.Name"></a>
        @if (!string.IsNullOrEmpty(Model.Rezept.BildPfad))
        {
            <img src="@Model.Rezept.BildPfad" class="card-img-top recipe-img" alt="@Model.Rezept.Name"
                 onerror="this.style.display='none'">
        }
        else
        {
            <div class="card-img-top recipe-img-placeholder d-flex align-items-center justify-content-center">
                <span class="placeholder-symbol">&#127859;</span>
            </div>
        }
        <div class="card-body">
            <h3 class="card-title">@Model.Rezept.Name</h3>
            <span class="badge bg-secondary">@Model.Rezept.Kategorie</span>

            @if (!string.IsNullOrEmpty(Model.Rezept.Beschreibung))
            {
                <p class="card-text mt-3">@Model.Rezept.Beschreibung</p>
            }

            <div class="meta-strip mt-2">
                @if (Model.Rezept.Zubereitungszeit.HasValue)
                {
                    <span>@Model.Rezept.Zubereitungszeit Min</span>
                }
                <span class="ms-3">@Model.Rezept.Portionen Portionen</span>
            </div>

            <div class="mt-4 d-flex gap-2 justify-content-center flex-wrap card-actions">
                <a asp-page="/Rezepte/Details" asp-route-id="@Model.Rezept.Id" class="btn btn-primary">Details ansehen</a>
                <a asp-page="/Random" class="btn btn-outline-secondary">Nochmal auslosen</a>
            </div>
        </div>
    </article>

    <a asp-page="/Index" class="btn btn-link mt-4">Zurück zur Übersicht</a>
</section>
