# Environment variables for KüchenRezepte
# Copy this file and set real values via your shell, Docker, or CI/CD environment.
# NEVER commit actual secrets to version control.

# API key for the mealplan endpoints (/api/mealplan/*)
# Leave empty to allow unauthenticated access (development only).
KUECHENREZEPTE_MEALPLAN_API_KEY=your-api-key-here

# Alexa Skill ID for the Alexa webhook (/api/alexa)
# Leave empty to skip Skill-ID validation.
KUECHENREZEPTE_ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
